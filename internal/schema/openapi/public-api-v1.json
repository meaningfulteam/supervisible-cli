                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    },
                    "description": "Bulk upsert payload."
                  }
                },
                "required": ["items"],
                "example": {
                  "items": [
                    {
                      "userId": "019cb675-c4df-7f8b-8a83-5f28581f5e7e",
                      "projectId": "019cb675-c4d6-7e90-8806-25e5145c3a06",
